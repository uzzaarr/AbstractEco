# Dune Analytics API key — used by `npm run fetch-dune` to refresh public/data/*.json.
# In CI this is read from the GitHub repo secret DUNE_API_KEY (not from Vercel env).
DUNE_API_KEY=

# Optional extra ecosystem-tracker keys (currently unused by fetch-dune)
ETHERSCAN_API_KEY=
COINMARKETCAP_API_KEY=
